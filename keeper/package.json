{
  "name": "volmarket-keeper",
  "version": "0.1.0",
  "description": "Autonomous settlement keeper: watches TxLINE feeds, fetches Merkle proofs, and resolves on-chain markets via CPI into TxLINE's validator.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "mock": "tsx src/index.ts --mock",
    "check:worldcup": "tsx scripts/check-worldcup-coverage.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.3",
    "bn.js": "^5.2.1",
    "dotenv": "^16.4.5",
    "eventsource": "^2.0.2",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
