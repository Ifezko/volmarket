# --- Solana ---
# CONFIRMED (TxLINE support via Discord): Level 12 (real-time World Cup) only exists on
# devnet right now, not mainnet. Keep this on devnet for real-time markets.
TXLINE_NETWORK=devnet
SOLANA_RPC_URL=
KEEPER_KEYPAIR=/home/you/.config/solana/id.json
# Deployed hosts: paste the keypair as a JSON byte array here instead of shipping a file.
# Takes PRIORITY over KEEPER_KEYPAIR when set. NEVER commit a real value — inject it via
# your host's secret manager (Railway/Fly/systemd EnvironmentFile), keep it blank here.
KEEPER_SECRET_KEY=
PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS
# Self-contained IDL copied into keeper/ (git-ignored). Copy it after `anchor build`:
#   cp ../signal_markets/target/idl/signal_markets.json ./signal_markets.idl.json
IDL_PATH=./signal_markets.idl.json

# --- TxLINE / TxODDS Oracle ---
# Real API host per github.com/txodds/tx-on-chain — NOT txline.txodds.com (docs site)
# or txline-dev.txodds.com (separate Swagger UI). Leave blank to use the network default
# (oracle.txodds.com / oracle-dev.txodds.com).
TXLINE_BASE_URL=
TXLINE_STREAM_URL=
# Real txoracle program + SPL token mint (leave blank to use network defaults):
#   devnet:  6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J / GYdhNurtx2EgiTPRHVGuFWKHPycdpUqgedVkwEVUWVTC
#   mainnet: 9ExbZjAapQww1vfcisDmrngPinHTEfpjYRWMunJgcKaA / sLX1i9dfmsuyFBmJTWuGjjRmG4VPWYK6dRRKSM4BCSx
TXLINE_PROGRAM_ID=
TXLINE_TOKEN_MINT=
# 1  = World Cup & Int Friendlies, free, 60s-delayed (works on devnet + mainnet)
# 12 = World Cup & Int Friendlies, free, real-time (devnet only — confirmed via Discord)
TXLINE_SERVICE_LEVEL=1
# Set true to skip the on-chain subscribe flow entirely and use a bare guest JWT —
# only works if your competition is one of their JWT-gated free leagues.
# Run `npm run check:worldcup` first to find out.
TXLINE_GUEST_ONLY=false
# Leave blank to run the real subscribe -> sign -> activate flow at startup (see auth.ts).
# Set only if you already have a provisioned token and want to skip the on-chain step.
TXLINE_API_KEY=

# --- Behaviour ---
POLL_INTERVAL_MS=15000
DEADLINE_SWEEP_MS=30000
LOG_LEVEL=info
