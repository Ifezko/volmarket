# --- Solana ---
# CONFIRMED (TxLINE support via Discord): Level 12 (real-time World Cup) only exists on
# devnet right now, not mainnet. Keep this on devnet for real-time markets.
TXLINE_NETWORK=devnet
SOLANA_RPC_URL=
KEEPER_KEYPAIR=~/.config/solana/id.json
# Deployed hosts: paste the keypair as a JSON byte array here instead of shipping a file.
# Takes PRIORITY over KEEPER_KEYPAIR when set. NEVER commit a real value — inject it via
# your host's secret manager (Railway/Fly/systemd EnvironmentFile), keep it blank here.
KEEPER_SECRET_KEY=
PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS
# Self-contained IDL copied into keeper/ (git-ignored). Copy it after `anchor build`:
#   cp ../signal_markets/target/idl/signal_markets.json ./signal_markets.idl.json
IDL_PATH=./signal_markets.idl.json

# --- TxLINE / TxODDS Oracle ---
# API host per the live OpenAPI spec (docs.yaml v1.5.2) `servers:` block — prod is
# txline.txodds.com, devnet is txline-dev.txodds.com. The old oracle*.txodds.com hosts
# were renamed and no longer resolve. Leave blank to use the network default.
TXLINE_BASE_URL=
TXLINE_STREAM_URL=
# The validator program resolve_market CPIs into, passed as the `txline_program` account.
# The program accepts exactly two addresses:
#   real txoracle   devnet 6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
#                  mainnet 9ExbZjAapQww1vfcisDmrngPinHTEfpjYRWMunJgcKaA
#   mock_validator         FPnwSSp2DXcNvJnxXWc2JXvU4MLNfrWDT6wBcU5Eptse
# Blank defaults to the REAL txoracle for the network — NOT the mock. Pair this with
# MOCK_VALIDATOR below, which controls the proof payload, not the program:
#   mock path (demo): TXLINE_PROGRAM_ID=FPnwSSp2...  + MOCK_VALIDATOR=true
#   real validator:   TXLINE_PROGRAM_ID blank/6pW64gN1... + MOCK_VALIDATOR=false
# Setting only one sends a stub proof to the real validator, which rejects it.
TXLINE_PROGRAM_ID=
# true (default) builds a stub proof; false fetches a real TxLINE Merkle proof.
# Selects the PROOF PAYLOAD only — see TXLINE_PROGRAM_ID above for the program.
MOCK_VALIDATOR=true
# SPL token mint (leave blank to use network defaults):
#   devnet:  GYdhNurtx2EgiTPRHVGuFWKHPycdpUqgedVkwEVUWVTC
#   mainnet: sLX1i9dfmsuyFBmJTWuGjjRmG4VPWYK6dRRKSM4BCSx
TXLINE_TOKEN_MINT=
# 1  = World Cup & Int Friendlies, free, 60s-delayed (works on devnet + mainnet)
# 12 = World Cup & Int Friendlies, free, real-time (devnet only — confirmed via Discord)
TXLINE_SERVICE_LEVEL=1
# Set true to skip the on-chain subscribe flow entirely and use a bare guest JWT —
# only works if your competition is one of their JWT-gated free leagues.
# Run `npm run check:worldcup` first to find out.
TXLINE_GUEST_ONLY=false
# Leave blank to run the real subscribe -> sign -> activate flow at startup (see auth.ts).
# Set only if you already have a provisioned token and want to skip the on-chain step.
TXLINE_API_KEY=

# --- Behaviour ---
POLL_INTERVAL_MS=15000
DEADLINE_SWEEP_MS=30000
LOG_LEVEL=info
