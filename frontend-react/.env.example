VITE_PRIVY_APP_ID=

# RPC endpoint the app uses for ALL reads + writes. It MUST support getProgramAccounts (the app
# lists markets and finds your positions with it). Notes:
#   - Public devnet (https://api.devnet.solana.com, the default) allows it but rate-limits → 429.
#   - Alchemy FREE tier BLOCKS getProgramAccounts (400) — only works on Pay-As-You-Go+.
#   - Helius / QuickNode free tiers DO support it — recommended. e.g. Helius:
#       VITE_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# This key is BAKED INTO THE FRONTEND BUNDLE and visible in the browser — that's expected for a
# browser app. Protect it by allowlisting your domain(s) in the provider's dashboard, not by hiding it.
VITE_RPC_URL=

# Optional read fallback tried when the primary throttles/fails (set full URL OR just the key).
# Only useful for a provider that supports getProgramAccounts on your plan.
VITE_ALCHEMY_RPC_URL=
VITE_ALCHEMY_API_KEY=
