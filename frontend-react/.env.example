VITE_PRIVY_APP_ID=
# Optional: defaults to https://api.devnet.solana.com if unset.
VITE_RPC_URL=
# Optional Alchemy devnet fallback for read calls (getProgramAccounts) when the primary RPC
# throttles (429). Set EITHER the full URL or just the API key. If VITE_RPC_URL is unset,
# Alchemy (when configured here) also becomes the primary endpoint.
VITE_ALCHEMY_RPC_URL=
VITE_ALCHEMY_API_KEY=
